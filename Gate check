BOT_TOKEN = "7707742168:AAGYX7yJBHjm-aVECNFHJ8n68YMPRThD76w"

bot = telebot.TeleBot(BOT_TOKEN, parse_mode="HTML")

headers = {
    "User-Agent": "Mozilla/5.0"
